# Database Configuration
# Set DATABASE=mysql to use TiDB/MySQL, otherwise SQLite is used
DATABASE=sqlite

# TiDB/MySQL Connection Settings (only used when DATABASE=mysql)
TIDB_HOST=gateway01-privatelink.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=rYrNmzH81Pyk4MT.root
TIDB_PASSWORD=<PASSWORD>
TIDB_DATABASE=sys
TIDB_USE_SSL=true

# SQLite Database Path (only used when DATABASE=sqlite)
BIOMETRIC_DB_FILE=backend/data/attendance.db

# Device Configuration
DEVICE_CONFIG_FILE=devices.json

# Auto-Sync Settings
AUTO_SYNC_INTERVAL=60

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_TLS=true
EMAIL_REPORT_ENABLED=false
EMAIL_REPORT_TIME=23:30

